#!/bin/bash
# Xnix 构建运行脚本
#
# 用法:
#   ./run              ISO 启动（增量编译）
#   ./run -b           清理重建后运行
#   ./run -n           只编译不运行
#   ./run --disk       磁盘启动（构建 disk_template）
#   ./run -d           调试模式
#

set -e

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
BUILD_DIR="$PROJECT_ROOT/build"

# 默认配置
CLEAN_BUILD=false
NO_RUN=false
BOOT_MODE="iso"  # iso | disk
DEBUG=false
CONFIG_PATH=""
QEMU_EXTRA=""
EXTRA_DISKS=()   # 挂载的磁盘列表，格式 "file:type"

# 帮助信息
show_help() {
    cat << 'EOF'
Xnix 构建运行脚本

用法: ./run [选项]

选项:
  -h, --help            显示帮助
  -b, --build           清理重建（删除 build 目录）
  -n, --no-run          只编译不运行
  -i, --iso             ISO 模式（默认）
  --disk                磁盘启动模式（构建 disk_template）
  -d, --debug           调试模式（GDB 端口 1234）
  -c, --config PATH     用户服务配置路径
  --attach FILE[:TYPE]  附加磁盘镜像（可重复，TYPE: ide/virtio/scsi，默认 ide）
  --qemu "ARGS"         额外 QEMU 参数

示例:
  ./run                              # 增量编译 + ISO 启动
  ./run -b                           # 清理重建 + ISO 启动
  ./run -n -b                        # 清理重建（只编译）
  ./run --disk                       # 磁盘模式启动
  ./run -d                           # ISO 调试模式
  ./run --attach build/disk_template.img            # 附加 IDE 磁盘，/mnt/sda1 可见
  ./run --attach sda.img --attach sdb.img:ide       # 挂载两块 IDE 磁盘
  ./run --attach data.img:virtio                    # 附加 VirtIO 磁盘
  ./run --qemu "-m 256M -smp 4"
EOF
}

# 解析参数
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            show_help
            exit 0
            ;;
        -b|--build)
            CLEAN_BUILD=true
            shift
            ;;
        -n|--no-run)
            NO_RUN=true
            shift
            ;;
        -i|--iso)
            BOOT_MODE="iso"
            shift
            ;;
        --disk)
            BOOT_MODE="disk"
            shift
            ;;
        -d|--debug)
            DEBUG=true
            shift
            ;;
        -c|--config)
            CONFIG_PATH="$2"
            shift 2
            ;;
        --attach)
            EXTRA_DISKS+=("$2")
            shift 2
            ;;
        --qemu)
            QEMU_EXTRA="$2"
            shift 2
            ;;
        *)
            echo "未知选项: $1"
            echo "使用 --help 查看帮助"
            exit 1
            ;;
    esac
done

JOBS=$(nproc 2>/dev/null || echo 4)

# 清理重建
if $CLEAN_BUILD; then
    echo "清理 build 目录..."
    rm -rf "$BUILD_DIR"
fi

# 初始化构建目录
if [ ! -d "$BUILD_DIR" ]; then
    mkdir -p "$BUILD_DIR"
fi

cd "$BUILD_DIR"

# 配置（如果需要）
if [ ! -f "CMakeCache.txt" ]; then
    echo "配置 CMake..."
    cmake ..
fi

# 编译
echo "编译（$JOBS 核心）..."
if [ "$BOOT_MODE" = "disk" ]; then
    cmake --build . -j$JOBS --target disk_template
elif [ "$BOOT_MODE" = "iso" ]; then
    cmake --build . -j$JOBS --target iso
fi

# 只编译不运行
if $NO_RUN; then
    echo "编译完成"
    exit 0
fi

# 处理自定义配置
if [ -n "$CONFIG_PATH" ]; then
    if [ ! -f "$CONFIG_PATH" ]; then
        echo "错误: 配置文件不存在: $CONFIG_PATH"
        exit 1
    fi
    echo "部署用户配置: $CONFIG_PATH"
    cp "$CONFIG_PATH" "$BUILD_DIR/generated/services.conf"
    if [ "$BOOT_MODE" = "iso" ]; then
        cmake --build . -j$JOBS --target iso
    fi
fi

# 构建 QEMU 命令
QEMU_CMD="qemu-system-i386"
QEMU_ARGS="-serial stdio -no-reboot -m 4096M -smp 2"

# 附加磁盘（每块先复制到 build/disk_<n>.img，保护原始镜像）
disk_idx=0
for disk_entry in "${EXTRA_DISKS[@]}"; do
    disk_file="${disk_entry%%:*}"
    disk_type="${disk_entry#*:}"
    # 若没有 ':' 分隔，则 disk_type == disk_file，默认用 ide
    if [ "$disk_type" = "$disk_file" ]; then
        disk_type="ide"
    fi
    if [ ! -f "$disk_file" ]; then
        echo "错误: 磁盘镜像不存在: $disk_file"
        exit 1
    fi
    disk_copy="$BUILD_DIR/disk_${disk_idx}.img"
    echo "复制磁盘: $disk_file -> $disk_copy (type=$disk_type)"
    cp "$disk_file" "$disk_copy"
    QEMU_ARGS="$QEMU_ARGS -drive file=$disk_copy,format=raw,if=$disk_type"
    disk_idx=$((disk_idx + 1))
done

# 调试模式
if $DEBUG; then
    QEMU_ARGS="$QEMU_ARGS -s -S"
    echo ""
    echo "调试模式：在另一个终端运行:"
    echo "  gdb build/xnix.elf -ex 'target remote :1234'"
    echo ""
fi

# 额外参数
if [ -n "$QEMU_EXTRA" ]; then
    QEMU_ARGS="$QEMU_ARGS $QEMU_EXTRA"
fi

# 运行
if [ "$BOOT_MODE" = "disk" ]; then
    echo "从磁盘启动..."
    echo "QEMU: $QEMU_CMD -hda disk_template.img $QEMU_ARGS"
    $QEMU_CMD -hda disk_template.img $QEMU_ARGS
elif [ "$BOOT_MODE" = "iso" ]; then
    echo "从 ISO 启动..."
    echo "QEMU: $QEMU_CMD -cdrom xnix.iso -boot d $QEMU_ARGS"
    $QEMU_CMD -cdrom xnix.iso -boot d $QEMU_ARGS
fi
